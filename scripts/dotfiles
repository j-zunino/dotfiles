#!/usr/bin/env bash
set -euo pipefail

DOTFILES="$(cd "$(dirname "$0")/.." && pwd)"
HOST="$(hostname)"
USER="$(whoami)"
BLUE='\033[0;34m'
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

case "${1:-}" in
    --host)
        HOST="$2"
        shift 2
        ;;
esac

CMD="${1:-}"

case "$CMD" in
    update)
        echo -e "${BLUE} Updating flake inputs...${NC}"
        nix flake update "$DOTFILES"
        echo -e "${GREEN} Flake inputs updated${NC}"
        ;;
    switch | build | boot)
        echo -e "${BLUE} Rebuild system $CMD for $HOST...${NC}"
        sudo nixos-rebuild "$CMD" --flake "$DOTFILES#$HOST"
        echo -e "${GREEN} Rebuild $CMD complete${NC}"
        ;;
    home)
        echo -e "${BLUE} Rebuilding home-manager for $USER@$HOST...${NC}"
        home-manager switch --flake "$DOTFILES#$USER@$HOST"
        echo -e "${GREEN} Home-manager rebuild complete${NC}"
        ;;
    format)
        echo -e "${BLUE} Formatting Nix...${NC}"
        alejandra "$DOTFILES"
        echo -e "${BLUE} Formatting Lua...${NC}"
        stylua "$DOTFILES"
        echo -e "${GREEN} Formatting complete${NC}"
        ;;
    *)
        echo "($DOTFILES)"
        echo "Usage: $(basename "$0") <command> [--host <host>]"
        echo ""
        echo "Commands:"
        echo "  update   Update flake inputs"
        echo "  switch   Rebuild and switch to new NixOS generation"
        echo "  build    Build new NixOS generation without switching"
        echo "  boot     Build and set as boot default without switching"
        echo "  home     Rebuild home-manager"
        echo "  format   Format nix and lua files"
        exit 1
        ;;
esac
